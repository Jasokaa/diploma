{"file":"forgot-password-BtQrnmSh.js","mappings":";;;;;;;;;;;;;;;;AAMA,UAAM,QAAQ,IAAI,EAAE;AACpB,UAAM,gBAAgB,IAAI,EAAE;AAC5B,UAAM,mBAAmB,IAAI,KAAK;AAElC,UAAM,EAAE,UAAA,IAAc,WAAA;;;uBAqBXA,eAAAC,WAAA,EAAA,OAAM,4BAAwB,MAAA,CAAA,CAAA,yiBAAAC,cAAA,SAclBC,MAAA,KAAA,CAAK,CAAA,wLAAA;AAWX,UAAAA,MAAA,aAAA,GAAa;6EACjBA,MAAA,aAAA,CAAa,CAAA,MAAA;AAAA,MAAA,OAAA;;;AAGT,UAAAA,MAAA,gBAAA,GAAgB;;;;;;QAIf,IAAG;AAAA,QAAY,OAAM;AAAA,MAAA,GAAA;AAAA,yBAA/B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;;;8BAFuD,0BAElE;AAAA,YAAA;AAAA;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderAttr","_unref","_push","_parent"],"sources":["../../../../../../../pages/forgot-password.vue"],"sourcesContent":["<!-- This page lets the user request a password reset email for local development. -->\n<script setup lang=\"ts\">\ndefinePageMeta({\n  middleware: ['guest']\n})\n\nconst email = ref('')\nconst statusMessage = ref('')\nconst resetRequestSent = ref(false)\n\nconst { $supabase } = useNuxtApp()\n\nconst handleSubmit = async () => {\n  statusMessage.value = ''\n  resetRequestSent.value = false\n\n  const { error } = await $supabase.auth.resetPasswordForEmail(email.value, {\n    redirectTo: 'http://localhost:3000/reset-password'\n  })\n\n  if (error) {\n    statusMessage.value = error.message\n    return\n  }\n\n  statusMessage.value = 'Check this email to reset your password. Please note: the email will be sent only if this address was registered before.'\n  resetRequestSent.value = true\n}\n</script>\n\n<template>\n  <section class=\"page-section auth-page\">\n    <div class=\"auth-page__layout auth-page__layout--single\">\n      <div class=\"surface-card auth-page__form\">\n        <div class=\"auth-page__heading\">\n          <span class=\"eyebrow\">gifttt</span>\n          <h1>Reset your password</h1>\n          <p>Enter your email and we will send you a link to set a new password.</p>\n        </div>\n\n        <form class=\"auth-page__inner-form\" @submit.prevent=\"handleSubmit\">\n          <label class=\"auth-page__field\" for=\"email\">\n            <span>Email</span>\n            <input\n              id=\"email\"\n              v-model=\"email\"\n              type=\"email\"\n              placeholder=\"name@example.com\"\n            >\n          </label>\n\n          <button type=\"submit\" class=\"button-primary auth-page__submit\">\n            Send reset email\n          </button>\n        </form>\n\n        <p v-if=\"statusMessage\" class=\"auth-page__status\">\n          {{ statusMessage }}\n        </p>\n\n        <p v-if=\"resetRequestSent\" class=\"auth-page__helper\">\n          If you are not sure you registered before or you do not have access to this email, register a new account.\n        </p>\n\n        <NuxtLink to=\"/register\" class=\"button-secondary auth-page__back\">\n          Return to registration\n        </NuxtLink>\n      </div>\n    </div>\n  </section>\n</template>\n\n<style scoped>\n.auth-page__layout {\n  width: min(100%, 62rem);\n  margin: 0 auto;\n}\n\n.auth-page__layout--single {\n  width: min(100%, 34rem);\n}\n\n.auth-page__form {\n  display: grid;\n  gap: 1rem;\n  padding: 1.7rem;\n  border-radius: 2rem;\n}\n\n.auth-page__heading,\n.auth-page__inner-form {\n  display: grid;\n  gap: 0.8rem;\n}\n\n.auth-page__heading h1,\n.auth-page__heading p,\n.auth-page__helper,\n.auth-page__status {\n  margin: 0;\n}\n\n.auth-page__heading p,\n.auth-page__helper {\n  color: var(--muted);\n}\n\n.auth-page__field {\n  display: grid;\n  gap: 0.45rem;\n}\n\n.auth-page__submit,\n.auth-page__back {\n  width: 100%;\n}\n\n.auth-page__status {\n  color: var(--danger);\n  font-size: 0.95rem;\n}\n</style>\n"],"version":3}